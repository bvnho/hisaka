@{
    ViewData["Title"] = "Trang chủ";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - HISAKA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #fde0e0;
            font-family: 'Segoe UI', sans-serif;
        }
        .navbar {
            background-color: #d45555;
        }
        .navbar-brand {
            font-weight: bold;
            color: white;
            font-size: 1.5rem;
        }
        .search-bar input {
            width: 400px;
            border-radius: 20px;
            padding: 0.5rem 1rem;
        }
        .discount-badge {
            position: absolute;
            top: 5px;
            left: 5px;
            background-color: #ff5722;
            color: white;
            padding: 2px 6px;
            font-size: 12px;
            border-radius: 4px;
        }
        .product-card {
            background: white;
            border-radius: 10px;
            padding: 10px;
            box-shadow: 0 1px 5px rgba(0,0,0,0.1);
            position: relative;
        }
        .footer {
            background-color: #d45555;
            color: white;
            padding: 2rem;
            font-size: 0.9rem;
        }
        .footer a {
            color: white;
            text-decoration: none;
        }
        .footer input {
            border-radius: 20px;
            border: none;
            padding: 5px 10px;
            width: 220px;
        }
        .footer button {
            background-color: #ff9800;
            color: white;
            border: none;
            border-radius: 20px;
            padding: 5px 20px;
            margin-left: 5px;
        }
    </style>
</head>
<body>

    <!-- Sản phẩm nổi bật -->
<div class="container my-4">
        <div class="d-flex justify-content-between">
            <h5 class="text-danger fw-bold">Sản phẩm nổi bật</h5>
            <a href="#" class="text-danger">Xem Tất Cả Sản Phẩm &gt;</a>
        </div>
        <div class="row row-cols-2 row-cols-md-4 row-cols-lg-6 g-3 mt-2">
            <div class="col">
                <div class="product-card text-center">
                    <img src="~/images/la roche-posay.png" class="w-100 mb-2" alt="Innisfree" onerror="this.src='https://via.placeholder.com/100x150/FF5733/FFFFFF'">
                    <div class="fw-bold text-dark">699.000₫</div>
                    <div style="font-size: 0.8rem;">La Roche-Posay</div>
                    <div style="font-size: 0.75rem; color: gray;">Kem Dưỡng La Roche-Posay Giúp Phục Hồi Da Đa Công Dụng 100ml</div>
                </div>
            </div>

            <div class="col">
                <div class="product-card text-center">
                    <img src="~/images/anessa.png" class="w-100 mb-2" alt="Innisfree">
                    <div class="fw-bold text-dark">441.000₫</div>
                    <div style="font-size: 0.8rem;">Anessa</div>
                    <div style="font-size: 0.75rem; color: gray;">Sữa Chống Nắng Anessa Cho Da Nhạy Cảm & Trẻ Em 60ml</div>
                </div>
            </div>

            <div class="col">
                <div class="product-card text-center">
                    <img src="~/images/skin1004.png" class="w-100 mb-2" alt="Bioderma">
                    <div class="fw-bold text-dark">265.000₫</div>
                    <div style="font-size: 0.8rem;">Skin1004</div>
                    <div style="font-size: 0.75rem; color: gray;">Kem Chống Nắng Skin1004 Cho Da Nhạy Cảm SPF 50+ 50ml</div>
                </div>
            </div>

            <div class="col">
                <div class="product-card text-center">
                    <img src="~/images/Cocoon.png" class="w-100 mb-2" alt="Laneige">
                    <div class="fw-bold text-dark">295.000₫</div>
                    <div style="font-size: 0.8rem;">Cocoon</div>
                    <div style="font-size: 0.75rem; color: gray;">Combo 2 Nước Tẩy Trang Bí Đao Cocoon Làm Sạch & Giảm Dầu 500ml</div>
                </div>
            </div>

            <div class="col">
                <div class="product-card text-center">
                    <img src="~/images/anessaa.png" class="w-100 mb-2" alt="Some By Mi">
                    <div class="fw-bold text-dark">451.000₫</div>
                    <div style="font-size: 0.8rem;">Anessa</div>
                    <div style="font-size: 0.75rem; color: gray;">Sữa Chống Nắng Anessa Dưỡng Da Kiềm Dầu 60ml</div>
                </div>
            </div>

            <div class="col">
                <div class="product-card text-center">
                    <img src="~/images/bioderma.png" class="w-100 mb-2" alt="COSRX">
                    <div class="fw-bold text-dark">327.000₫</div>
                    <div style="font-size: 0.8rem;">Bioderma</div>
                    <div style="font-size: 0.75rem; color: gray;">Nước Tẩy Trang Bioderma Dành Cho Da Nhạy Cảm 500ml</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sản phẩm bán chạy -->
<div class="container my-5">
    <h5 class="text-danger fw-bold">Sản Phẩm Bán Chạy</h5>
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3 mt-2">
        <!-- Sản phẩm 1: CeraVe -->
        <div class="col">
            <div class="product-card text-center">
                <img src="~/images/cerave-sua-rua-mat.png" class="w-100 mb-2" alt="CeraVe" 
                     onerror="this.src='https://via.placeholder.com/100x150/FF5733/FFFFFF'">
                <div class="fw-bold text-dark">329.000₫</div>
                <div style="font-size: 0.8rem;">CeraVe</div>
                <div style="font-size: 0.75rem; color: gray;">Sữa Rửa Mặt CeraVe Cho Da Thường Đến Da Khô 473ml</div>
            </div>
        </div>
        
        <!-- Sản phẩm 2: Klairs -->
        <div class="col">
            <div class="product-card text-center">
                <img src="~/images/klairs-serum-vitamin-c.png" class="w-100 mb-2" alt="Klairs" 
                     onerror="this.src='https://via.placeholder.com/100x150/33A8FF/FFFFFF'">
                <div class="fw-bold text-dark">275.000₫</div>
                <div style="font-size: 0.8rem;">Klairs</div>
                <div style="font-size: 0.75rem; color: gray;">Serum Vitamin C Klairs Làm Sáng Da Mờ Thâm 35ml</div>
            </div>
        </div>
        
        <!-- Sản phẩm 3: Some By Mi -->
        <div class="col">
            <div class="product-card text-center">
                <img src="~/images/some-by-mi-toner.png" class="w-100 mb-2" alt="Some By Mi" 
                     onerror="this.src='https://via.placeholder.com/100x150/33FF57/000000'">
                <div class="fw-bold text-dark">245.000₫</div>
                <div style="font-size: 0.8rem;">Some By Mi</div>
                <div style="font-size: 0.75rem; color: gray;">Nước Hoa Hồng Some By Mi AHA-BHA-PHA 30 Days Miracle 150ml</div>
            </div>
        </div>
        
        <!-- Sản phẩm 4: Laneige -->
        <div class="col">
            <div class="product-card text-center">
                <img src="~/images/laneige-mat-na-ngu-moi.png" class="w-100 mb-2" alt="Laneige" 
                     onerror="this.src='https://via.placeholder.com/100x150/A833FF/FFFFFF'">
                <div class="fw-bold text-dark">380.000₫</div>
                <div style="font-size: 0.8rem;">Laneige</div>
                <div style="font-size: 0.75rem; color: gray;">Mặt Nạ Ngủ Môi Laneige Dưỡng Ẩm Chuyên Sâu 20g</div>
            </div>
        </div>
        
        <!-- Sản phẩm 5: COSRX -->
        <div class="col">
            <div class="product-card text-center">
                <img src="~/images/cosrx-snail-essence.png" class="w-100 mb-2" alt="COSRX" 
                     onerror="this.src='https://via.placeholder.com/100x150/FF33A8/FFFFFF'">
                <div class="fw-bold text-dark">349.000₫</div>
                <div style="font-size: 0.8rem;">COSRX</div>
                <div style="font-size: 0.75rem; color: gray;">Tinh Chất Ốc Sên COSRX Advanced Snail 96 Mucin 150ml</div>
            </div>
        </div>
        
        <!-- Sản phẩm 6: Innisfree -->
        <div class="col">
            <div class="product-card text-center">
                <img src="~/images/innisfree-mat-na-dat-set.png" class="w-100 mb-2" alt="Innisfree" 
                     onerror="this.src='https://via.placeholder.com/100x150/F6FF33/000000'">
                <div class="fw-bold text-dark">215.000₫</div>
                <div style="font-size: 0.8rem;">Innisfree</div>
                <div style="font-size: 0.75rem; color: gray;">Mặt Nạ Đất Sét Innisfree Super Volcanic Pore Clay Mask 100ml</div>
            </div>
        </div>
    </div>
</div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
